#!/usr/bin/make -f

%:
	dh $@

# No unit is auto-enabled/started by the package: cloudberryos-setup enables
# cloudberryos-firewall.service once a student account exists, enables
# cloudberryos-home@<user>.service per child, and enables
# cloudberryos-admin.service whenever --admin-panel resolves to local/tailnet
# (see docs/packaging-goal.md "Systemd units", "Admin panel", and the
# "Systemd unit location" Locked Decision).
override_dh_installsystemd:
	dh_installsystemd --name=cloudberryos-firewall --no-enable --no-start
	dh_installsystemd --name=cloudberryos-home@ --no-enable --no-start
	dh_installsystemd --name=cloudberryos-admin --no-enable --no-start

# Hand-rolled install step: this repo has no upstream build system (dh_auto_install
# no-ops), and the package layout needs two renames/duplications that a plain
# debian/install file cannot express --
#   - tools/cloudberryos-resource.py ships twice: as /usr/bin/cloudberryos-resource
#     (renamed, no .py, the parent-facing CLI) AND as
#     /usr/share/cloudberryos/tools/cloudberryos-resource.py (same name, loaded by
#     cloudberryos_common.load_resource_module() next to cloudberryos_common.py
#     itself -- see that module's module docstring).
#   - the systemd unit files must land at their final path before
#     override_dh_installsystemd (above) looks for them there.
override_dh_install:
	install -D -m 0755 usr/bin/cloudberryos-setup debian/cloudberryos/usr/bin/cloudberryos-setup
	install -D -m 0755 usr/bin/cloudberryos-browser debian/cloudberryos/usr/bin/cloudberryos-browser
	install -D -m 0755 usr/bin/cloudberryos-admin debian/cloudberryos/usr/bin/cloudberryos-admin
	install -D -m 0755 tools/cloudberryos-resource.py debian/cloudberryos/usr/bin/cloudberryos-resource
	install -D -m 0755 usr/sbin/cloudberryos-apply debian/cloudberryos/usr/sbin/cloudberryos-apply
	install -D -m 0755 usr/libexec/cloudberryos/cloudberryos-firewall-apply debian/cloudberryos/usr/libexec/cloudberryos/cloudberryos-firewall-apply
	install -D -m 0644 usr/lib/systemd/system/cloudberryos-firewall.service debian/cloudberryos/usr/lib/systemd/system/cloudberryos-firewall.service
	install -D -m 0644 "usr/lib/systemd/system/cloudberryos-home@.service" "debian/cloudberryos/usr/lib/systemd/system/cloudberryos-home@.service"
	install -D -m 0644 usr/lib/systemd/system/cloudberryos-admin.service debian/cloudberryos/usr/lib/systemd/system/cloudberryos-admin.service
	install -D -m 0644 usr/share/applications/cloudberryos-browser.desktop debian/cloudberryos/usr/share/applications/cloudberryos-browser.desktop
	install -D -m 0644 usr/share/applications/cloudberryos-home.desktop debian/cloudberryos/usr/share/applications/cloudberryos-home.desktop
	install -D -m 0755 tools/build.py debian/cloudberryos/usr/share/cloudberryos/tools/build.py
	install -D -m 0644 tools/cloudberryos_common.py debian/cloudberryos/usr/share/cloudberryos/tools/cloudberryos_common.py
	install -D -m 0644 tools/cloudberryos-resource.py debian/cloudberryos/usr/share/cloudberryos/tools/cloudberryos-resource.py
	install -D -m 0755 tools/polish_user.sh debian/cloudberryos/usr/share/cloudberryos/tools/polish_user.sh
	install -D -m 0644 config/resources.json debian/cloudberryos/usr/share/cloudberryos/config/resources.json
	install -D -m 0644 assets/cloudberryos-home.css debian/cloudberryos/usr/share/cloudberryos/assets/cloudberryos-home.css
	install -D -m 0644 assets/cloudberryos-wallpaper-3840.png debian/cloudberryos/usr/share/cloudberryos/assets/cloudberryos-wallpaper-3840.png
	install -D -m 0644 assets/icons/cloudberryos-browser.svg debian/cloudberryos/usr/share/cloudberryos/assets/icons/cloudberryos-browser.svg
	install -D -m 0644 assets/icons/cloudberryos-offline-wikipedia.svg debian/cloudberryos/usr/share/cloudberryos/assets/icons/cloudberryos-offline-wikipedia.svg
	install -D -m 0644 assets/icons/cloudberryos-projects.svg debian/cloudberryos/usr/share/cloudberryos/assets/icons/cloudberryos-projects.svg
	install -D -m 0644 assets/icons/cloudberryos-request-shelf.svg debian/cloudberryos/usr/share/cloudberryos/assets/icons/cloudberryos-request-shelf.svg
	install -D -m 0644 assets/icons/cloudberryos-browser.svg debian/cloudberryos/usr/share/icons/hicolor/scalable/apps/cloudberryos-browser.svg
	install -D -m 0644 assets/icons/cloudberryos-offline-wikipedia.svg debian/cloudberryos/usr/share/icons/hicolor/scalable/apps/cloudberryos-offline-wikipedia.svg
	install -D -m 0644 assets/icons/cloudberryos-projects.svg debian/cloudberryos/usr/share/icons/hicolor/scalable/apps/cloudberryos-projects.svg
	install -D -m 0644 assets/icons/cloudberryos-request-shelf.svg debian/cloudberryos/usr/share/icons/hicolor/scalable/apps/cloudberryos-request-shelf.svg
	install -D -m 0644 migrations/001-initial.py debian/cloudberryos/usr/share/cloudberryos/migrations/001-initial.py
	# NOT under usr/share/doc/: cloudberryos_common.find_apps_doc() reads this
	# at runtime (the wizard app-name gate), and dpkg's own Docker base images
	# path-exclude=/usr/share/doc/* (except copyright/changelog.*) -- see that
	# function's docstring.
	install -D -m 0644 docs/apps.md debian/cloudberryos/usr/share/cloudberryos/apps.md
