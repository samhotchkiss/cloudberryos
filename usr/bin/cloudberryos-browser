#!/usr/bin/env bash
# Static (non-generated) CloudberryOS browser launcher.
#
# M1 de-templates this script (it used to be baked per-install by
# tools/build.py with an absolute --target path) and removes the
# self-spawned `python3 -m http.server` + PID-file logic entirely
# (prototype defect #8: the PID file was never reaped and the spawned
# server raced the packaged cloudberryos-home@.service unit for port
# 8765). The homepage server is now exclusively owned by
# cloudberryos-home@<user>.service; this launcher only health-checks it
# and tells the parent how to investigate on failure.
set -euo pipefail

HOME_URL="http://127.0.0.1:8765/home/index.html"
TARGET_URL="${1:-$HOME_URL}"
STATE_DIR="${HOME}/.cloudberryos"
LOG_FILE="$STATE_DIR/browser.log"
mkdir -p "$STATE_DIR"

log() {
  printf '[%s] %s\n' "$(date --iso-8601=seconds)" "$*" >> "$LOG_FILE"
}

health_check() {
  python3 - "$HOME_URL" <<'PY' >/dev/null 2>&1
import sys
import urllib.request

try:
    with urllib.request.urlopen(sys.argv[1], timeout=1.5) as response:
        raise SystemExit(0 if response.status < 500 else 1)
except Exception:
    raise SystemExit(1)
PY
}

if ! health_check; then
  student_user="$(id -un)"
  log "CloudberryOS homepage server not responding at $HOME_URL"
  echo "CloudberryOS's homepage isn't responding right now." >&2
  echo "Ask a parent to check: systemctl status cloudberryos-home@${student_user}" >&2
fi

export http_proxy="http://127.0.0.1:3128"
export https_proxy="http://127.0.0.1:3128"
export HTTP_PROXY="$http_proxy"
export HTTPS_PROXY="$https_proxy"
export no_proxy="localhost,127.0.0.1,::1"
export NO_PROXY="$no_proxy"
export MOZ_ENABLE_WAYLAND=1

if command -v firefox >/dev/null 2>&1; then
  FIREFOX_BIN="$(command -v firefox)"
elif [[ -x /snap/bin/firefox ]]; then
  FIREFOX_BIN="/snap/bin/firefox"
else
  log "Firefox executable not found"
  echo "Firefox is not installed. Ask a parent to run: snap install firefox" >&2
  exit 127
fi

log "Launching $FIREFOX_BIN --new-window $TARGET_URL"
nohup "$FIREFOX_BIN" --new-window "$TARGET_URL" >> "$LOG_FILE" 2>&1 &
