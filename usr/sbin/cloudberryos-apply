#!/usr/bin/env python3
"""Regenerate CloudberryOS artifacts from /etc/cloudberryos/resources.json
and re-apply the squid conffile and child-home polish.

Per docs/packaging-goal.md Locked Decisions ("Update flow", "Squid
integration"): cloudberryos-apply reads only profile.json (never
install.env) and fails loudly if required fields are missing; it never
touches /etc/squid/squid.conf except through the whole-file-replace,
parse-before-commit, idempotent-no-op-on-unchanged-content strategy
implemented in cloudberryos_common.apply_squid. This is deliberately never
called from a maintainer script (Debian Policy 10.7.4 bars a maintainer
script from touching another package's conffile) -- only cloudberryos-setup
and cloudberryos-apply may write it.
"""
import argparse
import copy
import importlib.util
import re
import sys
from pathlib import Path

_TOOLS_DIR_CANDIDATES = [
    Path("/usr/share/cloudberryos/tools"),
    # repo checkout: usr/sbin/cloudberryos-apply -> usr/sbin -> usr -> repo root
    Path(__file__).resolve().parent.parent.parent / "tools",
]
for _candidate in _TOOLS_DIR_CANDIDATES:
    if (_candidate / "cloudberryos_common.py").exists():
        sys.path.insert(0, str(_candidate))
        break
else:
    raise SystemExit("cloudberryos-apply: cannot locate cloudberryos_common.py")

import cloudberryos_common as common  # noqa: E402


def warn(message):
    print(f"cloudberryos-apply: warning: {message}", file=sys.stderr)


# ---------------------------------------------------------------------------
# Migrations runner (docs/packaging-goal.md Locked Decisions -- "Migrations").
#
# Migration-module contract: each file under the migrations directory is
# named `NNN-description.py` where NNN is a zero-padded (or plain) integer.
# It must define:
#
#   SCHEMA_VERSION = NNN          (int; must equal the filename's number --
#                                  a mismatch is a hard runner error)
#
# and may define either or both of:
#
#   def upgrade_profile(d: dict) -> dict: ...
#   def upgrade_resources(d: dict) -> dict: ...
#
# Each hook receives the *current in-memory* dict for that state file (the
# on-disk file is never touched mid-chain) and returns the upgraded dict
# (returning a mutated version of the same dict is fine). The runner sets
# `schema_version` to NNN itself after a hook returns, so hooks do not need
# to (and should not rely on) set it themselves. A hook must be safe to
# have its net effect applied to an already-migrated file (idempotent) --
# in practice this is automatic because the runner only invokes a
# migration's hook for a file when that file's current schema_version is
# below NNN, so a given step is never invoked twice for the same file.
#
# A migration that defines only ONE of the two hooks (e.g. a
# resources-only catalog migration) simply has no effect on the other
# state file: that file is neither transformed nor written, and its
# schema_version does not advance for that step -- a later migration that
# DOES define its hook is still compared against that file's true,
# unmoved current schema_version. This is why, e.g., a resources-only
# migration never changes profile.json at all (not even its
# schema_version) -- profile.json stays byte-identical on disk.
#
# Runner semantics:
#   - schema_version is an int in both profile.json and resources.json;
#     missing (or non-int) means 0.
#   - Discover /usr/share/cloudberryos/migrations/NNN-*.py, sorted
#     ascending by NNN.
#   - For each state file that exists on disk (profile.json ->
#     upgrade_profile, resources.json -> upgrade_resources), run every
#     migration with NNN > that file's current schema_version, ascending,
#     against an in-memory copy only.
#   - Only after EVERY targeted file's entire chain succeeds does the
#     runner write anything, each via atomic temp-file + rename
#     (common.write_json_atomic). If any migration raises, the whole
#     runner aborts non-zero and NOTHING is written -- no file is left
#     half-migrated, and files whose chains already succeeded before the
#     failure are also left untouched (writes only happen after every
#     chain across every file has completed).
#   - Fresh install (neither profile.json nor resources.json exists) is an
#     explicit no-op, exit 0 -- postinst runs --migrate on every configure
#     including first install and must never fail because of this step.
# ---------------------------------------------------------------------------

_MIGRATION_FILENAME_RE = re.compile(r"^(\d+)-.+\.py$")


def _discover_migrations(migrations_dir):
    """Return [(nnn:int, path:Path), ...] sorted ascending by nnn."""
    found = []
    for path in migrations_dir.glob("*.py"):
        match = _MIGRATION_FILENAME_RE.match(path.name)
        if not match:
            continue
        found.append((int(match.group(1)), path))
    found.sort(key=lambda pair: pair[0])
    return found


def _load_migration_module(nnn, path):
    spec = importlib.util.spec_from_file_location(f"cb_migration_{nnn}", path)
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    declared = getattr(module, "SCHEMA_VERSION", None)
    if declared != nnn:
        raise RuntimeError(
            f"{path.name}: SCHEMA_VERSION is {declared!r}, expected {nnn} "
            "(must match the filename's leading number)"
        )
    return module


def _schema_version_of(data):
    """schema_version is an int; missing (or a non-int value) means 0."""
    version = data.get("schema_version", 0)
    if not isinstance(version, int) or isinstance(version, bool):
        return 0
    return version


def default_migrations_dir():
    return common._first_existing([
        Path("/usr/share/cloudberryos/migrations"),
        common.find_repo_root() / "migrations",
    ])


def run_migrate(migrations_dir=None, profile_path=None, resources_path=None):
    """The full migrations runner. Parameters are overridable only for unit
    testing -- production call sites (postinst via `--migrate`) always use
    the defaults, which resolve to the real /etc/cloudberryos state files
    and the packaged (or repo-checkout) migrations directory.
    """
    profile_path = Path(profile_path) if profile_path is not None else common.PROFILE_PATH
    resources_path = Path(resources_path) if resources_path is not None else common.RESOURCES_PATH

    if not profile_path.exists() and not resources_path.exists():
        print("cloudberryos-apply --migrate: no state files present, nothing to migrate")
        return 0

    if migrations_dir is None:
        migrations_dir = default_migrations_dir()
    migration_files = _discover_migrations(migrations_dir) if migrations_dir else []
    if not migration_files:
        print("cloudberryos-apply --migrate: no migrations to run")
        return 0

    targets = [
        (profile_path, "upgrade_profile"),
        (resources_path, "upgrade_resources"),
    ]

    pending_writes = []  # [(path, dict), ...] -- nothing is written until every chain succeeds
    for path, hook_name in targets:
        if not path.exists():
            continue
        data = common.load_json(path, default=None)
        if data is None:
            continue
        current_version = _schema_version_of(data)

        working = copy.deepcopy(data)
        touched = False
        for nnn, mod_path in migration_files:
            if nnn <= current_version:
                continue
            try:
                module = _load_migration_module(nnn, mod_path)
                hook = getattr(module, hook_name, None)
                if hook is None:
                    # This migration file has nothing to say about this
                    # particular state file (e.g. a resources-only
                    # migration next to profile.json) -- it neither
                    # transforms it nor advances its schema_version. A
                    # later migration that DOES define this file's hook is
                    # still compared against the file's true, unmoved
                    # current_version, so it applies normally.
                    continue
                working = hook(working)
                if not isinstance(working, dict):
                    raise TypeError(f"{hook_name} in {mod_path.name} must return a dict")
                working["schema_version"] = nnn
                touched = True
            except Exception as exc:
                die(f"migration {mod_path.name} failed while upgrading {path}: {exc}")
        if touched:
            pending_writes.append((path, working))

    if not pending_writes:
        print("cloudberryos-apply --migrate: all state files already at the latest schema_version")
        return 0

    for path, data in pending_writes:
        common.write_json_atomic(path, data)
    for path, data in pending_writes:
        print(f"cloudberryos-apply --migrate: {path} migrated to schema_version {data['schema_version']}")
    return 0


def die(message):
    print(f"cloudberryos-apply: {message}", file=sys.stderr)
    raise SystemExit(1)


def run_migrate_install_env():
    """Internal hook used only by debian/postinst: fold a prototype
    /etc/cloudberryos/install.env into profile.json (see
    cloudberryos_common.migrate_install_env and docs/packaging-goal.md
    "State file" / the postinst spec under "Maintainer scripts"). No-op
    (exit 0) if install.env is absent, which is what keeps a fresh
    `apt install` postinst-safe.
    """
    if common.migrate_install_env():
        print("cloudberryos-apply --migrate-install-env: migrated a prototype install.env into profile.json")
    return 0


def main():
    parser = argparse.ArgumentParser(description="Regenerate CloudberryOS artifacts and re-apply squid.")
    parser.add_argument("--migrate", action="store_true", help="Run the migrations runner and exit")
    parser.add_argument("--migrate-install-env", action="store_true", help=argparse.SUPPRESS)
    args = parser.parse_args()

    if args.migrate_install_env:
        return run_migrate_install_env()

    if args.migrate:
        return run_migrate()

    profile = common.load_profile()
    if not profile:
        die("no /etc/cloudberryos/profile.json found -- run 'sudo cloudberryos-setup' first")

    missing = [field for field in ("child_name", "student_user") if not profile.get(field)]
    if missing:
        die(f"profile.json is missing required field(s): {', '.join(missing)}")

    if not common.RESOURCES_PATH.exists():
        die(f"no {common.RESOURCES_PATH} found -- run 'sudo cloudberryos-setup' first")

    errors = common.validate_resources(common.RESOURCES_PATH)
    if errors:
        print(f"cloudberryos-apply: {common.RESOURCES_PATH} failed validation:", file=sys.stderr)
        for error in errors:
            print(f"  - {error}", file=sys.stderr)
        raise SystemExit(1)

    common.VAR_DIR.mkdir(parents=True, exist_ok=True)
    artifacts = common.build_artifacts(common.RESOURCES_PATH, common.VAR_DIR, profile.get("child_name"))
    common.copy_assets(common.VAR_DIR)

    # allowed-domains.txt must exist before any squid parse/reload.
    common.ETC_DIR.mkdir(parents=True, exist_ok=True)
    common.atomic_write(common.ALLOWED_DOMAINS_PATH, artifacts["allowed_domains"], mode=0o644)

    deferred = not common.systemd_available()

    if profile.get("squid_managed"):
        common.apply_squid(artifacts["squid_conf"], deferred, warn)

    if profile.get("install_browser_policies"):
        common.write_browser_policies(common.VAR_DIR)

    student_user = profile.get("student_user")
    if student_user:
        no_desktop = (not common.gnome_shell_present()) or common.running_in_container()
        polish_script = common._first_existing([
            Path("/usr/share/cloudberryos/tools/polish_user.sh"),
            common.find_repo_root() / "tools" / "polish_user.sh",
        ])
        if polish_script is not None:
            polish_cmd = [
                "bash", str(polish_script),
                "--user", student_user,
                "--student", profile.get("child_name") or student_user,
                "--prefix", str(common.VAR_DIR),
            ]
            if no_desktop:
                polish_cmd.append("--no-desktop")
            result = common.run(polish_cmd, capture_output=False)
            if result.returncode != 0:
                warn(f"polish_user.sh exited {result.returncode}")

    print(f"CloudberryOS applied from {common.RESOURCES_PATH}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
